import streamlit as st
import yfinance as yf
import pandas as pd
import pandas_ta as ta

# --- PAGE CONFIGURATION ---
st.set_page_config(page_title="AI Stock Analyzer", layout="wide")
st.title("🛡️ BORSA-ASISTAN: AI OPERATION CENTER")
st.markdown("---")

# --- SIDEBAR: CONTROL PANEL ---
st.sidebar.header("📋 Control Panel")
# You can add more stocks here. Use .IS for Borsa Istanbul (e.g., SASA.IS)
stock_list = ["THYAO.IS", "SASA.IS", "EREGL.IS", "ASELS.IS", "SISE.IS", "AAPL", "TSLA"]
selected_stock = st.sidebar.selectbox("Select Stock to Track:", stock_list)
time_period = st.sidebar.selectbox("Time Period:", ["1mo", "3mo", "6mo", "1y"])

# --- DATA FETCHING ---
@st.cache_data
def get_data(ticker, period):
    df = yf.download(ticker, period=period, interval="1d")
    return df

data = get_data(selected_stock, time_period)

if not data.empty:
    # --- TECHNICAL ANALYSIS (AI LOGIC) ---
    # Calculate RSI (Relative Strength Index)
    data['RSI'] = ta.rsi(data['Close'], length=14)
    # Calculate SMA (Simple Moving Average)
    data['SMA20'] = ta.sma(data['Close'], length=20)
    
    current_price = data['Close'].iloc[-1]
    last_rsi = data['RSI'].iloc[-1]
    last_sma20 = data['SMA20'].iloc[-1]

    # --- AI DECISION ENGINE ---
    signal = "NEUTRAL / HOLD"
    confidence = "50%"
    status_type = "info"

    # Strategy: RSI + Trend Following
    if last_rsi < 35 and current_price > last_sma20:
        signal = "STRONG BUY"
        confidence = f"{int(100 - last_rsi)}%"
        status_type = "success"
    elif last_rsi > 65:
        signal = "SELL / TAKE PROFIT"
        confidence = f"{int(last_rsi)}%"
        status_type = "error"
    elif current_price < last_sma20:
        signal = "DOWNTREND / CAUTION"
        confidence = "75%"
        status_type = "warning"

    # --- USER INTERFACE DISPLAY ---
    col1, col2, col3 = st.columns(3)
    col1.metric("Current Price", f"{current_price:.2f}")
    col2.metric("RSI Value", f"{last_rsi:.2f}")
    col3.subheader(f"AI ANALYSIS: {signal}")

    if status_type == "success": 
        st.success(f"High Buying Interest! Confidence Level: {confidence}")
    elif status_type == "error": 
        st.error(f"Overbought Zone! Potential Correction Ahead. Confidence Level: {confidence}")
    elif status_type == "warning": 
        st.warning(f"Weak Trend! Manage Your Risks. Confidence Level: {confidence}")

    # Chart
    st.line_chart(data[['Close', 'SMA20']])
    
    st.markdown("### 📰 Market Insights")
    st.info(f"Technical data for {selected_stock} has been analyzed. RSI is at {last_rsi:.2f}. Stay disciplined.")

else:
    st.error("Data could not be retrieved. Please check the stock ticker.")
